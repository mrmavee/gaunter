# Network
LISTEN_ADDR=0.0.0.0:8080
INTERNAL_ADDR=127.0.0.1:8081
BACKEND_URL=http://127.0.0.1:9000
CONCURRENCY_LIMIT=1024
CLIENT_MAX_BODY_SIZE=10485760
RESPONSE_BUFFER_SIZE=10485760

# WAF
WAF_MODE=NORMAL
WAF_BODY_SCAN_ENABLED=true
WAF_BODY_SCAN_MAX_SIZE=32768
SSRF_ALLOWED_HOSTS=

# UI & Branding
APP_NAME=Gaunter
LOGO_PATH=
META_TITLE=Security Check
META_DESCRIPTION=Protected by Gaunter - Secure Access Gateway
META_KEYWORDS="tor, waf, security, privacy"

# Session & CAPTCHA
SESSION_SECRET=REPLACE_WITH_SECURE_32_BYTE_HEX_STRING
SESSION_EXPIRY_SECS=3600
CAPTCHA_ENABLED=true
CAPTCHA_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING
CAPTCHA_TTL=300
CAPTCHA_DIFFICULTY=medium
MAX_CAPTCHA_FAILURES=3
CAPTCHA_GEN_LIMIT=5

# Rate Limiting
RATE_LIMIT_RPS=6
RATE_LIMIT_BURST=10
RATE_LIMIT_SESSION_RPS=3
RATE_LIMIT_SESSION_BURST=5

# Tor Integration
# IPv6 prefix for circuit ID extraction (recommended: fc00)
TOR_CIRCUIT_PREFIX=
TOR_CONTROL_ADDR=127.0.0.1:9051
TOR_CONTROL_PASSWORD=REPLACE_WITH_TOR_CONTROL_PASSWORD
TORRC_PATH=/etc/tor/torrc
TOR_BW_ABUSE_THRESHOLD=52428800
TOR_STREAM_FLOOD_THRESHOLD=200

# Automated Defense (Attack Detection)
ATTACK_CHURN_THRESHOLD=30
ATTACK_RPS_THRESHOLD=30
ATTACK_RPC_THRESHOLD=5
ATTACK_DEFENSE_SCORE=2.0
ATTACK_POW_SCORE=4.0
ATTACK_POW_EFFORT=5
ATTACK_RECOVERY_SECS=300

# Defense Thresholds (Legacy)
DEFENSE_ERROR_RATE_THRESHOLD=0.15
DEFENSE_CIRCUIT_FLOOD_THRESHOLD=100
DEFENSE_COOLDOWN_SECS=300

# Restricted Paths
RESTRICTED_PATHS=
KARMA_THRESHOLD=50

# Webhooks
WEBHOOK_ENABLED=false
WEBHOOK_URL=
WEBHOOK_TOKEN=

# I2P Integration
I2P_ENABLED=false

# Security Headers
CSP_INJECTED=true
CSP_EXTRA_SOURCES=
COOP_POLICY=same-origin-allow-popups
COEP_ENABLED=false
HIDE_SERVER=false

# Logging
RUST_LOG=info
LOG_FORMAT=json
