# Tor Configuration File (torrc)
# Documentation: https://2019.www.torproject.org/docs/tor-manual.html.en
# DoS Defense Docs: https://community.torproject.org/onion-services/advanced/dos/

# Hidden Service Configuration
HiddenServiceDir /var/lib/tor/hidden_service/

# Map port 80 (Onion) to Gaunter port 8080 (Localhost via Sidecar)
HiddenServicePort 80 127.0.0.1:8080

# Logging
Log notice stdout
DataDirectory /var/lib/tor

# Control Port for Gaunter defense mechanisms (PoW, Circuit Killing)
ControlPort 127.0.0.1:9051
# Replace with hash from 'tor --hash-password <pwd>'
# See README.md for manual update instructions.
HashedControlPassword 16:CC9155A8ED3E10AD600A70FB95788FFB225A379BDCE91D16C3018D7DFB

# Export Circuit ID via PROXY protocol
HiddenServiceExportCircuitID haproxy

# Proof-of-Work
HiddenServicePoWDefensesEnabled 1
HiddenServicePoWQueueRate 50
HiddenServicePoWQueueBurst 100

# Intro Rate Limiting
HiddenServiceEnableIntroDoSDefense 1
HiddenServiceEnableIntroDoSRatePerSec 10
HiddenServiceEnableIntroDoSBurstPerSec 50

# Stream Limiting
HiddenServiceMaxStreams 20
HiddenServiceMaxStreamsCloseCircuit 1
